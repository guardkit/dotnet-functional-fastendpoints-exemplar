{
  "Authentication": {
    // Local Keycloak started via docker-compose in TASK-W5.
    "Authority": "http://localhost:8080/realms/exemplar",
    "Audience": "exemplar-api",
    "ClientId": "exemplar-api"
  },
  "ConnectionStrings": {
    // Local PostgreSQL started via docker-compose in TASK-W5.
    "DefaultConnection": "Host=localhost;Port=5432;Database=exemplar;Username=exemplar;Password=exemplar_dev"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  // OTEL_EXPORTER_OTLP_ENDPOINT is read by both OpenTelemetry SDK and Serilog.Sinks.OpenTelemetry.
  // Point at Aspire Dashboard (default port 18889) or any OTLP-compatible collector.
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:18889"
}
