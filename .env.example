# ============================================================
# Exemplar API — local docker-compose environment variables
# Copy to .env and fill in real values before running:
#   cp .env.example .env
# ============================================================

# ------ PostgreSQL ------------------------------------------
POSTGRES_DB=exemplar_db
POSTGRES_USER=exemplar
POSTGRES_PASSWORD=changeme

# Full connection string used by the API container.
# 'postgres' resolves to the postgres service name inside the Docker network.
DB_CONNECTION_STRING=Host=postgres;Database=exemplar_db;Username=exemplar;Password=changeme

# ------ Keycloak --------------------------------------------
KEYCLOAK_ADMIN_PASSWORD=changeme

# Authority URL — used by the API for JWT validation.
KEYCLOAK_AUTHORITY=http://localhost:8080/realms/exemplar

# Client ID and secret — must match the exemplar-realm.json import.
KEYCLOAK_CLIENT_ID=exemplar-api
KEYCLOAK_CLIENT_SECRET=REPLACE_ME_CLIENT_SECRET

# ------ OpenTelemetry ---------------------------------------
# OTLP gRPC endpoint for the Aspire Dashboard collector.
# Inside the Docker network the service is 'otel-collector'.
OTEL_ENDPOINT=http://otel-collector:4317
